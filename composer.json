{
    "name": "contao-garage/contao-global-elements",
    "description": "Contao 5 CMS module providing a backend module to help organizing numerously reused content elements outside the page and article tree.",
    "type": "contao-bundle",
    "keywords": ["contao bundle", "content organization"],
    "support": {
        "issues": "https://github.com/contao-garage/contao-global-elements/issues",
        "source": "https://github.com/contao-garage/contao-global-elements"
    },
    "homepage": "https://contao-garage.de",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin Schumann",
            "homepage": "https://github.com/martinschumann"
        }
    ],
    "require": {
        "php": "^8.2",
        "contao/core-bundle": "^5.3"
    },
    "conflict": {
       "contao/core-bundle": ">5.5 <5.7.4"
    },
    "require-dev": {
        "contao/test-case": "^5.4",
        "contao/easy-coding-standard": "^6.13",
        "contao/rector": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "ContaoGarage\\GlobalElements\\": "src/"
        },
        "classmap": [
            "contao/"
        ],
        "exclude-from-classmap": [
            "contao/config/",
            "contao/dca/",
            "contao/languages/",
            "contao/templates/"
        ]
    },
    "extra": {
        "contao-manager-plugin": "ContaoGarage\\GlobalElements\\ContaoManager\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "contao-components/installer": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
